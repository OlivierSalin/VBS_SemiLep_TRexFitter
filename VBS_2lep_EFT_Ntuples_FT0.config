% ------- %
% - JOB - %
% ------- %

Job: "VBS_SemiLep_aQGC_FT0"
	BlindingThreshold: 0.1
	CmeLabel: "13 TeV"
	GetChi2: True
	ReadFrom: NTUP
	NtuplePaths: /data/atlas/salin/VBS_mc/Intern/Run2/2L/NTuples
	NtupleName: "reco"
	MCweight: "weight_total_NOSYS"
	ImageFormat: pdf, png
	Label: "VBS Semi 2L"
	LegendNColumns: 1
	LegendX1: 0.6
	Lumi: 1
	LumiLabel: "140 fb^{-1}"
	OVERSIGSCALE: 10
	PlotOptions: YIELDS,"NORMSIG %", CHI2
	POI: FT0
	RatioYmax: 2
	RatioYmin: 0
	StatOnly: True
	SummaryLogY: True
	%BlindSRs: True




% ------- %
% - FIT - %
% ------- %


Fit: "fit"
	FitBlind: TRUE
	FitRegion: CRSR
	FitType: SPLUSB
  POIAsimov: 0.0
	UseMinos: "FT0"
  doLHscan: FT0
  LHscanMin: -0.4
  LHscanMax: 0.4
  LHscanSteps: 51
	SetRandomInitialNPval: 0.1
	SetRandomInitialNPvalSeed: 1234567



% --------------- %
% ---- LIMIT ---- %
% --------------- %

Limit: limit
  LimitType: ASYMPTOTIC
  LimitBlind: TRUE
  %SignalInjection: TRUE
  %SignalInjectionValue: XXX
  LimitPlot: TRUE

% ---------------------- %
% ---- SIGNIFICANCE ---- %
% ---------------------- %
Significance: Significance
  SignificanceType: ASYMPTOTIC
  SignificanceBlind: TRUE
  SignificancePlot: TRUE

% ----------- %
% - REGIONS - %
% ----------- %

Region: "TwoLep_NoTagger_ljet_leading_m"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "ljet_leading_m_NOSYS",20,0,200
  Binning: 0,10.5263,21.0526,31.5789,42.1053,52.6316,63.1579,73.6842,84.2105,94.7368,105.2632,115.7895,126.3158,136.8421,147.3684,157.8947,168.4211,178.9474,189.4737,200
  VariableTitle: "m_{J} [GeV]"
  Selection: ""
  Label: "NoTagger_ljet_m"
  ShortLabel: NoTagger_ljet_m
  LogScale: True

Region: "TwoLep_NoTagger_LeadingTagJet_pt"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "LeadingTagJet_pt_NOSYS",20,30,2000
  Binning: 30,133.6842,237.3684,341.0526,444.7368,548.4211,652.1053,755.7895,859.4737,963.1579,1066.8421,1170.5263,1274.2105,1377.8947,1481.5789,1585.2632,1688.9474,1792.6316,1896.3158,2000
  VariableTitle: "p_{T,j1} [GeV]"
  Selection: ""
  Label: "NoTagger_j1_pt"
  ShortLabel: NoTagger_j1_pt
  LogScale: True

Region: "TwoLep_NoTagger_SubLeadingTagJet_pt"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "SubLeadingTagJet_pt_NOSYS",20,30,600
  Binning: 30,60,90,120,150,180,210,240,270,300,330,360,390,420,450,480,510,540,570,600
  VariableTitle: "p_{T,j2} [GeV]"
  Selection: ""
  Label: "NoTagger_j2_pt"
  ShortLabel: NoTagger_j2_pt
  LogScale: True

Region: "TwoLep_NoTagger_TagJetsDeltaEta"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "TagJetsDeltaEta_NOSYS",20,-8,8
  Binning: -8,-7.1579,-6.3158,-5.4737,-4.6316,-3.7895,-2.9474,-2.1053,-1.2632,-0.4211,0.4211,1.2632,2.1053,2.9474,3.7895,4.6316,5.4737,6.3158,7.1579,8
  VariableTitle: "\Delta\eta_{jj}"
  Selection: ""
  Label: "NoTagger_deta_jj"
  ShortLabel: NoTagger_deta_jj
  LogScale: True

Region: "TwoLep_NoTagger_Njets"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "Njets_NOSYS",10,2,15
  Binning: 2,3,4,5,6,7,8,9,10,15
  VariableTitle: "N_{j}"
  Selection: ""
  Label: "NoTagger_njets"
  ShortLabel: NoTagger_njets
  LogScale: True

Region: "TwoLep_NoTagger_mVV"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "VVSystem_m_NOSYS",8,0,8000
  Binning: 0,500,1000,1500,2000,2500,3000,8000
  VariableTitle: "m_{VV} [GeV]"
  Selection: ""
  Label: "mVV_SR_HP"
  ShortLabel: mVV_SR_HP
  LogScale: True

Region: "TwoLep_SR_HP_mVV"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "VVSystem_m_NOSYS",8,0,8000
  Binning: 0,500,1000,1500,2000,2500,3000,8000
  VariableTitle: "m_{VV} [GeV]"
  Selection: "pass_3VarsBosonTagger50_NOSYS"
  Label: "mVV_SR_HP"
  ShortLabel: mVV_SR_HP
  LogScale: True

Region: "TwoLep_SR_LP_mVV"
  Type: SIGNAL
  DataType: ASIMOV
  Variable: "VVSystem_m_NOSYS",8,0,8000
  Binning: 0,500,1000,1500,2000,2500,3000,8000
  VariableTitle: "m_{VV} [GeV]"
  Selection: "(!pass_3VarsBosonTagger50_NOSYS) && pass_3VarsBosonTagger80_NOSYS"
  Label: "mVV_SR_LP"
  ShortLabel: mVV_SR_LP
  LogScale: True

Region: "TwoLep_ZCR"
	Type: CONTROL
  DataType: ASIMOV
	Variable: "mjj_NOSYS",6,400,5000
	VariableTitle: "m_{jj} [GeV]"
	Binning: 400,600,1000,1400,1800,2500,5000
  Selection: "!(pass_3VarsBosonTagger50_NOSYS || pass_3VarsBosonTagger80_NOSYS)"
  Label: "Z+jets CR"
  ShortLabel:ZCR



% ----------- %
% - SAMPLES - %
% ----------- %


Sample: "data"
  Title: Data
  Type: DATA
  NtupleFile: data

Sample: "Zjets"
  Title: Z+jets
  Type: BACKGROUND
  NtupleFile: Zjets
  FillColor: 862
  LineColor: 862

Sample: "QCDVV"
  Title: QCD-VV
  Type: BACKGROUND
  NtupleFile: QCDVV
  FillColor: 921
  LineColor: 921

Sample: "Top"
  Title: Top
  Type: BACKGROUND
  NtupleFile: Top
  FillColor: 797
  LineColor: 797

Sample: "Wjets"
  Title: W+jets
  Type: BACKGROUND
  NtupleFile: Wjets
  FillColor: 419
  LineColor: 419


Sample: "aQGC_FT0"
  Title: "FT0 QUAD"
  Type: SIGNAL
  NtupleFile: aQGC_FT0
  FillColor: 7
  LineColor: 7


Sample: "Signal"
  Title: "EWK VVjj"
  Type: BACKGROUND
  NtupleFile: Signal
  FillColor: 633
  LineColor: 633


% ----------------- %
% - NORM. FACTORS - %
% ----------------- %

NormFactor: "FT0"
	Max: 3
	Min: -3
	Nominal: 0.0
  Samples: NONE
	Title: "f_{T0}"


NormFactor: "FT0_QUAD"
	Max: 10
	Min: 0
	Nominal: 0.0
	Samples: aQGC_FT0
  Expression: (FT0*FT0):FT0[0.0,-3,3]
	Title: "f_{T0} QUAD"




% --------------- %
% - SYSTEMATICS - %
% --------------- %

